TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
DISCORD_BOT_TOKEN="your_discord_bot_token"

# --- Docker Compose Configuration ---
# The port where the backend will be accessible on the host machine
BACKEND_PORT=8000
# The port where the frontend will be accessible on the host machine
FRONTEND_PORT=3000

# The URL that the user's browser will use to connect to the backend.
# If deploying on a VPS, change localhost to your server's IP (e.g. http://143.12.33.22:8000)
NEXT_PUBLIC_BACKEND_URL="http://localhost:8000"

# (For local script running only - Docker ignores this because it uses Docker's internal network)
BACKEND_URL="http://127.0.0.1:8000"
